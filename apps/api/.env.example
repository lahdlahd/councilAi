# ---- Server ----------------------------------------------------------------
APP_ENV=development
PORT=8000
# Comma-separated allowed CORS origins (your Next.js dev + Vercel URL)
ALLOWED_ORIGINS=http://localhost:3000

# ---- Market data sources (PUBLIC — no key needed for market endpoints) ------
BITGET_REST_BASE=https://api.bitget.com
BITGET_WS_PUBLIC=wss://ws.bitget.com/v2/ws/public
COINGECKO_BASE=https://api.coingecko.com/api/v3
# Optional CoinGecko demo/pro key (raises rate limits). Leave blank to omit.
COINGECKO_API_KEY=

# ---- Indicators / candles ---------------------------------------------------
# Bitget v2 spot granularities: 1min, 5min, 15min, 30min, 1h, 4h, 6h, 12h, 1day
CANDLE_GRANULARITY=15min
CANDLE_LIMIT=200

# ---- Caching / HTTP ---------------------------------------------------------
SNAPSHOT_TTL_SEC=3.0
CANDLE_CACHE_TTL_SEC=15.0
HTTP_TIMEOUT_SEC=8.0

# ---- LLM: Qwen primary, OpenAI fallback -------------------------------------
# Leave BOTH keys blank to run the council in OFFLINE (data-driven) mode:
# agents reason deterministically over the REAL market snapshot. No fake market data.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=400
LLM_TIMEOUT_SEC=30.0

# ---- Ambient council session + streaming cadence ---------------------------
COUNCIL_SYMBOL=BTCUSDT            # the always-on session subject
COUNCIL_ROUND_INTERVAL_SEC=6.0    # pause between completed rounds
CADENCE_TOKENS_PER_SEC=18.0       # word-by-word streaming pace (demo polish)
THINKING_PAUSE_SEC=0.7            # how long the typing indicator shows first

# ---- Supabase (Trade Journal) ----------------------------------------------
# Leave blank to run without persistence (journal becomes a no-op).
# Use the SERVICE ROLE key (server-side only — never ship it to the frontend).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
